{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schema/evidence.schema.json",
  "title": "Atlas Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_id", "claim", "source_url", "accessed_at", "marketplace", "evidence_type", "confidence", "notes"],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^EVD-[0-9]{3,}$"},
    "claim": {"type": "string", "minLength": 1},
    "source_url": {"type": ["string", "null"], "format": "uri"},
    "accessed_at": {"type": "string", "format": "date"},
    "marketplace": {"enum": ["Etsy", "Cults3D", "Cross-market", "Internal"]},
    "evidence_type": {"enum": ["Verified", "Proxy", "Assumption", "Unknown"]},
    "confidence": {"enum": ["High", "Medium", "Low"]},
    "notes": {"type": "string", "minLength": 1}
  }
}
