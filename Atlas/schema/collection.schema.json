{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schema/collection.schema.json",
  "title": "Atlas Collection Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["collection_id", "name", "hero_product_id", "supporting_product_ids", "mini_version", "xl_version", "bundle_edition", "premium_edition", "commercial_license_edition", "future_physical_product", "future_expansion_opportunities", "status", "version", "owner", "review_date", "change_history"],
  "properties": {
    "collection_id": {"type": "string", "pattern": "^ATL-QA-[0-9]{3}$"},
    "name": {"type": "string", "minLength": 1},
    "hero_product_id": {"type": "string", "pattern": "^ATL-QA-[0-9]{3}-[0-9]{3}$"},
    "supporting_product_ids": {"type": "array", "minItems": 4, "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "pattern": "^ATL-QA-[0-9]{3}-[0-9]{3}$"}},
    "mini_version": {"type": "string", "minLength": 1},
    "xl_version": {"type": "string", "minLength": 1},
    "bundle_edition": {"type": "string", "minLength": 1},
    "premium_edition": {"type": "string", "minLength": 1},
    "commercial_license_edition": {"type": "string", "minLength": 1},
    "future_physical_product": {"type": "string", "minLength": 1},
    "future_expansion_opportunities": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "status": {"enum": ["Draft", "Experimental", "Approved", "Released", "Deprecated"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "owner": {"type": "string", "minLength": 1},
    "review_date": {"type": "string", "format": "date"},
    "change_history": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/change"}}
  },
  "$defs": {"change": {"type": "object", "additionalProperties": false, "required": ["version", "date", "change"], "properties": {"version": {"type": "string"}, "date": {"type": "string", "format": "date"}, "change": {"type": "string", "minLength": 1}}}}
}
